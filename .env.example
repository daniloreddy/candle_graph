# Candle Graph API Configuration
PORT=8000
HOST=127.0.0.1
DEV=true

# Docker only: address docker-compose.yml (prod) publishes PORT on.
# Default 127.0.0.1 = localhost-only. Set to 0.0.0.0 for LAN / reverse proxy / direct exposure.
BIND_HOST=127.0.0.1

# Comma-separated list of valid bearer tokens
API_TOKENS=dummy_token_1,dummy_token_2,secret_example_abc123

# Rate limit per IP (format: number/period — period: second, minute, hour, day)
RATE_LIMIT=20/minute

# Comma-separated list of proxy IPs allowed to set CF-Connecting-IP/X-Forwarded-For
# (default: 127.0.0.1). Leave as-is unless running behind a reverse proxy on another host.
TRUSTED_PROXIES=127.0.0.1

# IANA timezone used to display timestamps in the dashboard (default: UTC).
# Hot-reloadable: editable from the /config page, no restart needed.
TZ=UTC

# Dashboard auto-refresh (hot-reloadable via /config, defaults shown)
REFRESH_ENABLED=true
REFRESH_INTERVAL=30
